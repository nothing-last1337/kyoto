<div class="popular-games" style="--image-src: url(//d2rzzcn1jnr24x.cloudfront.net/Images/~normad-alpha/dark-gold/desktop/home/popular-games-background.jpg?v=20250528);">
    <div data-section="left" style="--image-src: url(//d2rzzcn1jnr24x.cloudfront.net/Images/~normad-alpha/dark-gold/desktop/layout/icon-sprite.png?v=20250528);">
        <div class="section-title">
            <i data-icon="play" style="--image-src: url(//d2rzzcn1jnr24x.cloudfront.net/Images/~normad-alpha/dark-gold/desktop/layout/icon-sprite.png?v=20250528);"></i>
            Video Slots Popular
        </div>
<div class="jackpot-winners">
  <div class="jackpot-winner-title">
    <i data-icon="trophy"
       style="--image-src: url(//d2rzzcn1jnr24x.cloudfront.net/Images/~normad-alpha/dark-gold/desktop/jackpot/trophy.png?v=20250528);"></i>
    PEMENANG MESIN SLOT
  </div>
  <div class="winners-ticker-container">
    <div class="winners-ticker" id="winners_ticker">
      <ul></ul>
    </div>
  </div>
</div>

<style>
.jackpot-winners {
  background: #000;
  padding: 6px 10px;
  border-radius: 4px;
  overflow: hidden;
}

.jackpot-winner-title {
  font-weight: bold;
  font-size: 13px;
  margin-bottom: 5px;
  display: flex;
  align-items: center;
  gap: 6px;
  color: #ffa303;
  text-transform: uppercase;
}

.winners-ticker-container {
  height: 26px;
  overflow: hidden;
  position: relative;
}

.winners-ticker ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.winners-ticker li {
  height: 26px;
  line-height: 26px;
  white-space: nowrap;
  padding-left: 4px;
  transform: translateY(100%);
  opacity: 0;
  position: absolute;
  width: 100%;
  transition: transform 0.6s ease, opacity 0.6s ease;
}

.winners-ticker li.active {
  transform: translateY(0);
  opacity: 1;
  position: relative;
}

.winners-ticker li.exit {
  transform: translateY(-100%);
  opacity: 0;
}

/* Warna teks */
.winner-name {
  font-weight: bold;
  color: #ffa303;
}
.winner-game {
  color: #ffa303;
  font-weight: 500;
}
.winner-amount {
  font-weight: bold;
  color: #ffa303;
}

</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const games = [
    "Gates of Olympus", "Starlight Princess", "Sweet Bonanza", "Mahjong Ways",
    "Wild West Gold", "Sugar Rush", "Power of Thor", "Big Bass Bonanza"
  ];

  function randomName() {
    const prefixes = ["Budi", "Joko", "Maya", "Andi", "Nana", "Rina", "Tono", "Lisa", "Asep", "Dian"];
    const suffix = Math.floor(Math.random() * 999);
    const name = prefixes[Math.floor(Math.random() * prefixes.length)] + suffix;
    // sensor tengahnya
    return name[0] + "***" + name.slice(-2);
  }

  function randomAmount() {
    const min = 1000000, max = 8000000;
    return "Rp " + Math.floor(Math.random() * (max - min) + min).toLocaleString("id-ID");
  }

  function createWinner() {
    return `<li>
      <span class="winner-name">${randomName()}</span>
      menang <span class="winner-game">${games[Math.floor(Math.random() * games.length)]}</span>
      sebesar <span class="winner-amount">${randomAmount()}</span>
    </li>`;
  }

  const ul = document.querySelector("#winners_ticker ul");
  for (let i = 0; i < 5; i++) {
    ul.innerHTML += createWinner();
  }

  const items = document.querySelectorAll("#winners_ticker li");
  let index = 0, prevIndex = null;

  function showNext() {
    if (prevIndex !== null) {
      items[prevIndex].classList.remove("active");
      items[prevIndex].classList.add("exit");
    }
    items[index].classList.remove("exit");
    items[index].classList.add("active");

    prevIndex = index;
    index = (index + 1) % items.length;

    // tiap kali cycle, replace dengan winner baru biar random terus
    if (index === 0) {
      ul.innerHTML = "";
      for (let i = 0; i < 5; i++) ul.innerHTML += createWinner();
    }
  }

  showNext();
  setInterval(showNext, 4000); // ganti tiap 4 detik
});
</script>


