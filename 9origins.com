<style>
.announcement-wrapper {
    height: 2.2em;
    overflow: hidden;
    position: relative;
}

.announcement-list {
    list-style: none;
    padding: 0;
    margin: 0;
    animation: scrollUp linear infinite;
    animation-duration: 20s;
}

.announcement-list li {
    height: 2.2em;
    line-height: 2.2em;
    white-space: nowrap;
}

@keyframes scrollUp {
    0%   { transform: translateY(0); }
    100% { transform: translateY(-100%); }
}

#progressive_jackpot {
    font-weight: 600;
    font-size: 40px;
    color: #ffa303;
    font-family: 'Orbitron', sans-serif;
    letter-spacing: 3px;

}

#popular_providers {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 5px 10px;
  margin: 0;
  list-style: none;
  overflow-x: auto;
  scrollbar-width: thin;
}

#popular_providers::-webkit-scrollbar {
  height: 6px;
}
#popular_providers::-webkit-scrollbar-thumb {
  background: #444;
  border-radius: 4px;
}

#popular_providers li {
  flex: 0 0 auto;
}

#popular_providers li a {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #111;
  border: 1px solid #333;
  border-radius: 6px;
  padding: 6px 12px;
  transition: all 0.3s ease;
  min-width: 110px;
  height: 50px;
}

#popular_providers li img {
  max-height: 30px;
  width: auto;
  display: block;
}

#popular_providers li.active a,
#popular_providers li a:hover {
  background: linear-gradient(180deg, #ffa303, #ffa303);
  border-color: #ffa303;
  transform: scale(1.05);
}

</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
    const list = document.getElementById("announcement_list");
    const clone = list.cloneNode(true);
    list.parentNode.appendChild(clone);
});

document.addEventListener("DOMContentLoaded", function() {
    const jackpotEl = document.getElementById("progressive_jackpot");

    let currentJackpot = 1200000000;
    const increment = 500 + Math.random() * 1500;
    const intervalTime = 100;

    function formatRupiah(angka) {
        return angka.toLocaleString("id-ID");
    }

    function updateJackpot() {
        currentJackpot += increment;
        jackpotEl.textContent = formatRupiah(Math.floor(currentJackpot));
    }

    setInterval(updateJackpot, intervalTime);
});
</script>



